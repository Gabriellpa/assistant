{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Contextual Desktop Assistant",
  "version": "0.1.0",
  "identifier": "com.gabriel.contextual-desktop-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Contextual Desktop Assistant",
        "width": 960,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
