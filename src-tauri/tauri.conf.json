{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Contextual Desktop Assistant",
  "version": "0.1.0",
  "identifier": "com.gabriel.contextual-desktop-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Contextual Desktop Assistant",
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": false,
        "visible": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
